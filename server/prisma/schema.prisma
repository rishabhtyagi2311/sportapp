generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model userInfo {
  id          Int             @id @default(autoincrement())
  firstname   String
  lastname    String
  email       String          @unique
  dob         String
  city        String
  contact     String          @unique

  footballProfile footballProfile?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model footballProfile {
  id         Int         @id @default(autoincrement())
  userId     Int         @unique
  nickname   String
  role       String
  experience String

  user       userInfo    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdTeams footballTeam[] @relation("CreatedTeams")
  memberTeams  footballTeamMember[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model footballTeam {
  id          Int                   @id @default(autoincrement())
  name        String
  location    String
  maxPlayers  Int
  createdById Int

  createdBy   footballProfile       @relation("CreatedTeams", fields: [createdById], references: [id])
  members     footballTeamMember[]

  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
}

model footballTeamMember {
  id               Int               @id @default(autoincrement())
  footballProfileId Int
  footballTeamId   Int

  footballProfile  footballProfile   @relation(fields: [footballProfileId], references: [id])
  footballTeam     footballTeam      @relation(fields: [footballTeamId], references: [id])

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([footballProfileId, footballTeamId])
}

model PartnerIdentity {
  id            String   @id @default(uuid())
  firstName     String
  lastName      String
  contactNumber String   @unique
  password      String   
  venues        Venue[]  
  createdAt     DateTime @default(now())
}



model Venue {
  id              String   @id @default(uuid())
  name            String
  description     String   @db.Text
  isActive        Boolean  @default(true)
  
  city            String   
  state           String
  pincode         String
  
  images          Image[]
  address         Address? 
  timeSlots       TimeSlot[]
  
  sports          Json     
  amenities       Json     
  
  contactInfo     Json     
  operatingHours  Json    
  partnerId       String
  partner         PartnerIdentity @relation(fields: [partnerId], references: [id]) 
  
  rating          Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TimeSlot {
  id          String   @id @default(uuid())
  venueId     String
  
  varietyId   String   
  varietyName String   
  
  date        DateTime
  startTime   String   
  endTime     String   
  price       Float
  status      String   @default("available")
  venue       Venue    @relation(fields: [venueId], references:[id], onDelete:Cascade)
  
  @@index([venueId, date, varietyId]) 
}

model Image {
  id      String @id @default(uuid())
  url     String
  venueId String
  venue   Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
}

model Address {
  id       String @id @default(uuid())
  street   String
  lat      Float?
  lng      Float?
  venueId  String @unique
  venue    Venue  @relation(fields: [venueId], references: [id], onDelete: Cascade)
}